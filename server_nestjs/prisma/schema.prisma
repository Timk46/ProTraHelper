// ==========================================
// EVALUATION SYSTEM ENUMS
// ==========================================

enum EvaluationStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  DISCUSSION
  COMPLETED
}

enum EvaluationPhase {
  DISCUSSION
  EVALUATION
}

// ==========================================
// EVALUATION SYSTEM MODELS
// ==========================================

model EvaluationSession {
  id          Int             @id @default(autoincrement())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  moduleId    Int
  createdById Int
  isActive    Boolean         @default(true)
  isAnonymous Boolean         @default(true)
  phase       EvaluationPhase @default(DISCUSSION)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  module      Module                 @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdBy   User                   @relation(fields: [createdById], references: [id])
  submissions EvaluationSubmission[]
  categories  EvaluationCategory[]

  @@map("evaluation_sessions")
}

model EvaluationSubmission {
  id          String           @id @default(cuid())
  title       String
  description String?
  authorId    Int
  pdfFileId   Int
  sessionId   Int
  status      EvaluationStatus @default(DRAFT)
  phase       EvaluationPhase  @default(DISCUSSION)
  submittedAt DateTime
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relations
  author      User                @relation(fields: [authorId], references: [id])
  pdfFile     FileUpload          @relation(fields: [pdfFileId], references: [id])
  session     EvaluationSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  discussions Discussion[]        @relation("EvaluationDiscussions")
  ratings     EvaluationRating[]
  comments    EvaluationComment[]
  ratings     EvaluationRating[]
  author      User                @relation(fields: [authorId], references: [id])
  pdfFile     File                @relation(fields: [pdfFileId], references: [id])
  session     EvaluationSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("evaluation_submissions")
}

model EvaluationCategory {
  id          Int      @id @default(autoincrement())
  sessionId   Int
  name        String
  displayName String
  description String?
  icon        String?
  color       String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  session     EvaluationSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  discussions Discussion[]        @relation("CategoryDiscussions")
  ratings     EvaluationRating[]
  comments    EvaluationComment[]
  ratings     EvaluationRating[]

  @@unique([sessionId, name])
  @@map("evaluation_categories")
}

model EvaluationRating {
  id           Int      @id @default(autoincrement())
  submissionId String
  categoryId   Int
  userId       Int
  rating       Int      @db.SmallInt // 0-10 rating
  comment      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  submission EvaluationSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  category   EvaluationCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user       User                 @relation(fields: [userId], references: [id])

  @@unique([submissionId, categoryId, userId])
  @@map("evaluation_ratings")
}

model EvaluationComment {
  id           String @id @default(cuid())
  submissionId String
  categoryId   Int
  userId       Int
  content      String @db.Text

  // Reply functionality - hierarchical comments
  parentId String?

  // Simplified voting system - store counts directly
  upvotes   Int @default(0)
  downvotes Int @default(0)

  // Vote tracking as JSON to avoid complex schema
  voteDetails Json? // {userVotes: {userId: "UP"|"DOWN"}}

  // Anonymous display name for this comment
  anonymousDisplayName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  submission EvaluationSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  category   EvaluationCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user       User                 @relation(fields: [userId], references: [id])

  // Self-referential relations for reply hierarchy
  parent  EvaluationComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies EvaluationComment[] @relation("CommentReplies")

  @@map("evaluation_comments")
}

model UserGroup {
  id                  Int                   @id @default(autoincrement())
  name                String
  maxSize             Int
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  UserGroupMembership UserGroupMembership[]
}

model UserGroupMembership {
  id        Int       @id @default(autoincrement())
  userId    Int
  groupId   Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  group     UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model GroupReviewGate {
  id               Int      @id @default(autoincrement())
  questionId       Int      @unique
  linkedQuestionId Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model QuestionCollection {
  id         Int                      @id @default(autoincrement())
  textHTML   String                   @db.Text
  questionId Int                      @unique
  question   Question                 @relation(fields: [questionId], references: [id], onDelete: Cascade)
  links      QuestionCollectionLink[] // Links to contained questions
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
}

model QuestionCollectionLink {
  id                     Int                @id @default(autoincrement())
  questionCollectionId   Int
  questionCollection     QuestionCollection @relation(fields: [questionCollectionId], references: [id], onDelete: Cascade)
  linkedContentElementId Int
  linkedContentElement   ContentElement     @relation(fields: [linkedContentElementId], references: [id], onDelete: Cascade)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
}

// RHINO SECURITY AUDIT LOG
model RhinoAuditLog {
  id                Int      @id @default(autoincrement())
  userId            Int
  userEmail         String
  operation         String // launch, focus, info, debug, config, window_query
  endpoint          String
  parameters        String?  @db.Text // JSON string of request parameters
  result            String // success, error, rate_limited, unauthorized
  errorMessage      String?  @db.Text
  ipAddress         String
  userAgent         String?  @db.Text
  sessionId         String?
  timestamp         DateTime @default(now())
  responseTime      Int? // milliseconds
  securityRiskLevel String   @default("low") // low, medium, high
  suspicious        Boolean  @default(false)
  suspiciousReason  String?  @db.Text

  // Index for performance on common queries
  @@index([userId, timestamp])
  @@index([operation, timestamp])
  @@index([suspicious, timestamp])
  @@index([result, timestamp])
  @@map("rhino_audit_logs")
}
