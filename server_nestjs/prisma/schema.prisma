generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       Int                          @id @default(autoincrement())
  email                    String                       @unique
  firstname                String
  lastname                 String
  password                 String
  createdAt                DateTime                     @default(now())
  globalRole               GlobalRole                   @default(STUDENT)
  currentconceptNodeId     Int?
  chatBotMessage           ChatBotMessage[]
  chatSessions             ChatSession[]
  codeSubmission           CodeSubmission[]
  codeSubmissionFile       CodeSubmissionFile[]
  EventLogs                EventLog[]
  Notification             Notification[]
  question                 Question[]
  currentConcept           ConceptNode?                 @relation(fields: [currentconceptNodeId], references: [id])
  userAnswer               UserAnswer[]
  conceptUser              UserConcept[]
  UserContentProgress      UserContentElementProgress[]
  UserContentView          UserContentView[]
  userMCAnswer             UserMCAnswer[]
  Vote                     Vote[]
  anonymousUser            anonymousUser[]
  userSubjects             UserSubject[]
  refreshTokens            RefreshToken[]
  updatedSettings          ModuleSetting[]
  hasAcceptedPrivacyPolicy Boolean                      @default(false)
  fileUploads              FileUpload[]
  UserGroupMembership      UserGroupMembership[]

  // EVALUATION SYSTEM RELATIONS
  evaluationSessionsCreated EvaluationSession[]
  evaluationSubmissions     EvaluationSubmission[]
  evaluationRatings         EvaluationRating[]
  evaluationComments        EvaluationComment[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  deviceId  String
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, deviceId])
}

model Module {
  id                      Int                       @id @default(autoincrement())
  name                    String                    @unique
  description             String
  goals                   ModuleConceptGoal[]
  subjects                Subject[]                 @relation("ModuleToSubject")
  settings                ModuleSetting[]
  ModuleHighlightConcepts ModuleHighlightConcepts[]
  fileUploads             FileUpload[]

  // EVALUATION SYSTEM RELATIONS
  evaluationSessions EvaluationSession[]
}

model ModuleConceptGoal {
  id            Int         @id @default(autoincrement())
  moduleId      Int
  conceptNodeId Int
  level         Int
  conceptNode   ConceptNode @relation(fields: [conceptNodeId], references: [id], onDelete: Cascade)
  module        Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Subject {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  description  String
  modules      Module[]      @relation("ModuleToSubject")
  userSubjects UserSubject[]
}

model UserSubject {
  id                  Int     @id @default(autoincrement())
  userId              Int
  subjectId           Int
  subjectSpecificRole String
  registeredForSL     Boolean @default(false)
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject             Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
}

model ConceptGraph {
  id     Int          @id @default(autoincrement())
  name   String
  rootId Int?         @unique
  root   ConceptNode? @relation(fields: [rootId], references: [id], onDelete: Cascade)
}

model ConceptNode {
  id                      Int                       @id @default(autoincrement())
  name                    String
  description             String?
  descriptionHTML         String?
  conceptGraphId          Int?
  transcript              String?
  childEdges              ConceptEdge[]             @relation("conceptEdgeParent")
  mySuccessors            ConceptEdge[]             @relation("prerequisiteConcept")
  myPrerequisites         ConceptEdge[]             @relation("successorConcept")
  myParents               ConceptFamily[]           @relation("childConcept")
  myChildren              ConceptFamily[]           @relation("parentConcept")
  conceptGraph            ConceptGraph?
  Discussion              Discussion[]
  moduleGoals             ModuleConceptGoal[]
  question                Question[]
  requiredBy              Requirement[]
  trainedBy               Training[]
  currentConceptFor       User[]
  userConcepts            UserConcept[]
  ModuleHighlightConcepts ModuleHighlightConcepts[]
}

model ConceptFamily {
  id       Int         @id @default(autoincrement())
  childId  Int
  parentId Int
  child    ConceptNode @relation("childConcept", fields: [childId], references: [id], onDelete: Cascade)
  parent   ConceptNode @relation("parentConcept", fields: [parentId], references: [id], onDelete: Cascade)
}

model ConceptEdge {
  id             Int         @id @default(autoincrement())
  prerequisiteId Int
  successorId    Int
  parentId       Int
  parent         ConceptNode @relation("conceptEdgeParent", fields: [parentId], references: [id], onDelete: Cascade)
  prerequisite   ConceptNode @relation("prerequisiteConcept", fields: [prerequisiteId], references: [id], onDelete: Cascade)
  successor      ConceptNode @relation("successorConcept", fields: [successorId], references: [id], onDelete: Cascade)
}

model ContentNode {
  id              Int               @id @default(autoincrement())
  name            String
  description     String?
  descriptionHTML String?
  position        Int?
  prerequisites   ContentEdge[]     @relation("prerequisiteContent")
  successors      ContentEdge[]     @relation("successorContent")
  ContentView     ContentView[]
  discussions     Discussion[]
  requires        Requirement[]
  trains          Training[]
  UserContentView UserContentView[]
}

model ContentEdge {
  id             Int         @id @default(autoincrement())
  prerequisiteId Int
  successorId    Int
  prerequisite   ContentNode @relation("prerequisiteContent", fields: [prerequisiteId], references: [id], onDelete: Cascade)
  successor      ContentNode @relation("successorContent", fields: [successorId], references: [id], onDelete: Cascade)
}

model Requirement {
  id            Int         @id @default(autoincrement())
  contentNodeId Int
  conceptNodeId Int
  conceptNode   ConceptNode @relation(fields: [conceptNodeId], references: [id], onDelete: Cascade)
  contentNode   ContentNode @relation(fields: [contentNodeId], references: [id], onDelete: Cascade)
}

model Training {
  id            Int         @id @default(autoincrement())
  contentNodeId Int
  conceptNodeId Int
  awards        Int?
  conceptNode   ConceptNode @relation(fields: [conceptNodeId], references: [id], onDelete: Cascade)
  contentNode   ContentNode @relation(fields: [contentNodeId], references: [id], onDelete: Cascade)
}

model UserConcept {
  id            Int                @id @default(autoincrement())
  userId        Int
  conceptNodeId Int
  level         Int?
  expanded      Boolean
  concept       ConceptNode        @relation(fields: [conceptNodeId], references: [id], onDelete: Cascade)
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  events        UserConceptEvent[]
}

model UserConceptEvent {
  id            Int                  @id @default(autoincrement())
  userConceptId Int
  eventType     userConceptEventType
  level         Int
  createdAt     DateTime             @default(now())
  userConcept   UserConcept          @relation(fields: [userConceptId], references: [id], onDelete: Cascade)
}

model ContentElement {
  id                  Int                          @id @default(autoincrement())
  type                contentElementType
  title               String?
  text                String?
  fileId              Int?                         @unique
  questionId          Int?                         @unique
  file                File?                        @relation(fields: [fileId], references: [id])
  question            Question?                    @relation(fields: [questionId], references: [id])
  ContentView         ContentView[]
  Discussion          Discussion[]
  UserContentProgress UserContentElementProgress[]
}

model File {
  id                   Int                   @id @default(autoincrement())
  uniqueIdentifier     String                @unique
  name                 String
  path                 String
  type                 String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  questionId           Int?
  mCAnswerId           Int?
  contentElementId     Int?
  contentElement       ContentElement?
  MCAnswer             MCOption?             @relation(fields: [mCAnswerId], references: [id])
  question             Question?             @relation(fields: [questionId], references: [id])
  TranscriptEmbeddings TranscriptEmbedding[]
  fileUploads          FileUpload[]
  UserUploadAnswer     UserUploadAnswer[]

  // EVALUATION SYSTEM RELATIONS
  evaluationSubmissions EvaluationSubmission[]
}

model ContentView {
  id               Int            @id @default(autoincrement())
  contentNodeId    Int
  contentElementId Int
  position         Int?
  isVisible        Boolean?       @default(true)
  contentElement   ContentElement @relation(fields: [contentElementId], references: [id], onDelete: Cascade)
  contentNode      ContentNode    @relation(fields: [contentNodeId], references: [id], onDelete: Cascade)
}

model Feedback {
  id           Int        @id @default(autoincrement())
  text         String
  userAnswerId Int
  score        Float
  userAnswer   UserAnswer @relation(fields: [userAnswerId], references: [id])
}

model Question {
  id                   Int      @id @default(autoincrement())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  name                 String?
  description          String?
  score                Float?
  type                 String
  level                Int      @default(1)
  mode                 String   @default("practise")
  authorId             Int
  text                 String
  isApproved           Boolean  @default(false)
  version              Int      @default(1)
  originId             Int?
  conceptNodeId        Int?
  // Rhino Integration Fields
  rhinoEnabled         Boolean  @default(false)
  rhinoGrasshopperFile String?
  rhinoSettings        Json?
  rhinoAutoLaunch      Boolean  @default(false)
  rhinoAutoFocus       Boolean  @default(true)

  codingQuestion             CodingQuestion?
  codeGameQuestion           CodeGameQuestion?
  contentElement             ContentElement?
  files                      File[]
  GraphQuestion              GraphQuestion?
  FreeTextQuestion           FreeTextQuestion[]
  mcQuestion                 MCQuestion[]
  mCSliderQuestion           MCSliderQuestion?
  author                     User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  conceptNode                ConceptNode?       @relation(fields: [conceptNodeId], references: [id])
  origin                     Question?          @relation("VersionControl", fields: [originId], references: [id], onDelete: Cascade)
  question                   Question[]         @relation("VersionControl")
  QuestionVersionAsQuestion  QuestionVersion[]  @relation("QuestionToQuestionVersion")
  QuestionVersionAsSuccessor QuestionVersion[]  @relation("QuestionToSuccessorQuestionVersion")
  userAnswer                 UserAnswer[]
  FillinQuestion             FillinQuestion?
  UmlQuestion                UmlQuestion?
  UploadQuestion             UploadQuestion[]
  GroupReviewGate            GroupReviewGate?
}

model QuestionVersion {
  id          Int          @id @default(autoincrement())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  questionId  Int
  successorId Int?
  version     Int
  isApproved  Boolean      @default(false)
  MCQuestion  MCQuestion[]
  question    Question     @relation("QuestionToQuestionVersion", fields: [questionId], references: [id], onDelete: Cascade)
  successor   Question?    @relation("QuestionToSuccessorQuestionVersion", fields: [successorId], references: [id])
}

model MCQuestion {
  id                Int                @id @default(autoincrement())
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  questionVersionId Int?
  questionId        Int
  textHTML          String?
  shuffleoptions    Boolean            @default(true)
  isSC              Boolean
  question          Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionVersion   QuestionVersion?   @relation(fields: [questionVersionId], references: [id])
  MCQuestionOption  MCQuestionOption[]
  userMCAnswers     UserMCAnswer[]
}

model MCOption {
  id                   Int                    @id @default(autoincrement())
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  text                 String
  is_correct           Boolean
  files                File[]
  MCQuestionOption     MCQuestionOption[]
  UserMCOptionSelected UserMCOptionSelected[]
}

model MCQuestionOption {
  id           Int        @id @default(autoincrement())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  mcQuestionId Int
  mcOptionId   Int
  option       MCOption   @relation(fields: [mcOptionId], references: [id], onDelete: Cascade)
  question     MCQuestion @relation(fields: [mcQuestionId], references: [id], onDelete: Cascade)
}

model UserMCAnswer {
  id              Int        @id @default(autoincrement())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  userId          Int
  mcQuestionId    Int
  isCorrectAnswer Boolean?
  question        MCQuestion @relation(fields: [mcQuestionId], references: [id])
  user            User       @relation(fields: [userId], references: [id])
}

model UserAnswer {
  id                    Int                    @id @default(autoincrement())
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  userId                Int
  questionId            Int
  userFreetextAnswer    String?
  userGraphAnswer       Json?
  graphAIFeedbacks      GraphAIFeedback[]
  feedbacks             Feedback[]
  question              Question               @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user                  User                   @relation(fields: [userId], references: [id])
  userMCOptionSelected  UserMCOptionSelected[]
  UserUmlQuestionAnswer UserUmlQuestionAnswer?
  codeGameAnswer        CodeGameAnswer[]
  UserUploadAnswer      UserUploadAnswer[]
}

model UserMCOptionSelected {
  id           Int        @id @default(autoincrement())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  userAnswerId Int
  mcOptionId   Int
  mcOption     MCOption   @relation(fields: [mcOptionId], references: [id], onDelete: Cascade)
  userAnswer   UserAnswer @relation(fields: [userAnswerId], references: [id], onDelete: Cascade)
}

model FreeTextQuestion {
  id                  Int      @id @default(autoincrement())
  textHTML            String?
  expectations        String
  expectationsHTML    String?
  exampleSolution     String?
  exampleSolutionHTML String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  questionId          Int
  question            Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model GraphQuestion {
  id               Int      @id @default(autoincrement())
  textHTML         String?
  expectations     String
  expectationsHTML String?
  type             String
  initialStructure Json
  exampleSolution  Json
  stepsEnabled     Boolean
  configuration    Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  questionId       Int      @unique
  question         Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model GraphAIFeedback {
  id              Int        @id @default(autoincrement())
  updatedAt       DateTime   @updatedAt
  createdAt       DateTime   @default(now())
  prompt          String?
  response        String
  ratingByStudent Int?
  userAnswerId    Int
  userAnswer      UserAnswer @relation(fields: [userAnswerId], references: [id])
}

model CodingQuestion {
  id                  Int              @id @default(autoincrement())
  count_InputArgs     Int
  text                String
  textHTML            String
  mainFileName        String
  programmingLanguage String
  expectations        String?
  questionId          Int              @unique
  automatedTests      AutomatedTest[]
  codeGerueste        CodeGeruest[]
  codeSubmissions     CodeSubmission[]
  modelSolutions      ModelSolution[]
  question            Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model CodeGeruest {
  id               Int            @id @default(autoincrement())
  codingQuestionId Int
  codeFileName     String
  code             String
  language         String?
  codingQuestion   CodingQuestion @relation(fields: [codingQuestionId], references: [id], onDelete: Cascade)
}

model ModelSolution {
  id               Int            @id @default(autoincrement())
  codingQuestionId Int
  codeFileName     String
  code             String
  language         String?
  codingQuestion   CodingQuestion @relation(fields: [codingQuestionId], references: [id], onDelete: Cascade)
}

model AutomatedTest {
  id             Int            @id @default(autoincrement())
  code           String
  testFileName   String?
  language       String?
  testClassName  String?
  runMethod      String?
  inputArguments String?
  questionId     Int
  codingQuestion CodingQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model CodeSubmission {
  id                  Int                  @id @default(autoincrement())
  code                String
  updatedAt           DateTime             @updatedAt
  createdAt           DateTime             @default(now())
  compilerOutput      String?
  unitTestResults     String?
  userId              Int
  codingQuestionId    Int
  score               Int?
  codingQuestion      CodingQuestion       @relation(fields: [codingQuestionId], references: [id], onDelete: Cascade)
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  CodeSubmissionFiles CodeSubmissionFile[]
  kiFeedback          KIFeedback[]
  generatedFeedbacks  GeneratedFeedback[] // Relation to GeneratedFeedback
}

model CodeSubmissionFile {
  id               Int            @id @default(autoincrement())
  updatedAt        DateTime       @updatedAt
  createdAt        DateTime       @default(now())
  version          Int
  code             String?
  language         String?
  codeFileName     String?
  userId           Int
  CodeSubmissionId Int
  CodeSubmission   CodeSubmission @relation(fields: [CodeSubmissionId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id])
}

model CodeGameQuestion {
  id                              Int                @id @default(autoincrement())
  text                            String
  programmingLanguage             String
  questionId                      Int                @unique
  codeSolutionRestriction         Boolean            @default(false)
  fileNameToRestrict              String?
  methodNameToRestrict            String?
  frequencyOfMethodNameToRestrict Int?
  codeGameScaffolds               CodeGameScaffold[]
  gameFileName                    String
  game                            String
  gameCellRestrictions            String? // TODO: remove optional = "?"
  theme                           String?            @default("dino") // TODO: remove optional = "?"
  question                        Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model CodeGameScaffold {
  id                 Int              @id @default(autoincrement())
  codeGameQuestionId Int
  codeFileName       String
  code               String
  language           String?
  visible            Boolean?
  mainFile           Boolean?
  codeGameQuestion   CodeGameQuestion @relation(fields: [codeGameQuestionId], references: [id], onDelete: Cascade)
}

model CodeGameAnswer {
  id                                Int                      @id @default(autoincrement())
  createdAt                         DateTime                 @default(now())
  updatedAt                         DateTime                 @updatedAt
  codeGameQuestionId                Int
  userAnswerId                      Int                      @unique
  userAnswer                        UserAnswer               @relation(fields: [userAnswerId], references: [id], onDelete: Cascade)
  codeGameScaffoldAnswers           CodeGameScaffoldAnswer[]
  codeGameExecutionResult           String
  codeSolutionRestriction           Boolean
  frequencyOfMethodEvaluationResult Boolean
  frequencyOfMethodCallsResult      Int
  reachedDestination                Boolean
  allItemsCollected                 Boolean
  totalItems                        Int
  collectedItems                    Int
  visitedCellsAreAllowed            Boolean
  allWhiteListCellsVisited          Boolean
  executionSuccess                  Boolean?
  executionMessage                  String?
}

model CodeGameScaffoldAnswer {
  id               Int            @id @default(autoincrement())
  language         String
  codeFileName     String
  code             String
  codeGameAnswerId Int
  CodeGameAnswer   CodeGameAnswer @relation(fields: [codeGameAnswerId], references: [id], onDelete: Cascade)
}

model ModuleSetting {
  id        Int      @id @default(autoincrement())
  key       String
  value     String   @db.Text // Using @db.Text for potentially large JSON strings
  moduleId  Int
  updatedAt DateTime @updatedAt
  updatedBy Int
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  updater   User     @relation(fields: [updatedBy], references: [id])

  @@unique([moduleId, key])
}

model ModuleHighlightConcepts {
  id            Int         @id @default(autoincrement())
  moduleId      Int
  module        Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  conceptNodeId Int
  conceptNode   ConceptNode @relation(fields: [conceptNodeId], references: [id], onDelete: Cascade)
  alias         String? // Optional alias for the concept
  description   String? // Optional description for the concept
  pictureData   String? // Stores the picture data as a base64 string or URL
  position      Int? // Optional position for ordering in the module
  isUnlocked    Boolean     @default(false)

  @@unique([moduleId, conceptNodeId])
}

model FillinQuestion {
  id         Int      @id @default(autoincrement())
  content    String // Stores sanitized HTML or structured JSON
  taskType   String
  table      Boolean
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  questionId Int      @unique
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  blanks     Blank[]
}

model Blank {
  id               Int            @id @default(autoincrement())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  blankContent     String
  position         String
  isDistractor     Boolean        @default(false)
  isCorrect        Boolean        @default(false)
  fillinQuestionId Int
  fillinQuestion   FillinQuestion @relation(fields: [fillinQuestionId], references: [id])
}

model KIFeedback {
  id                Int            @id @default(autoincrement())
  updatedAt         DateTime       @updatedAt
  createdAt         DateTime       @default(now())
  model             String
  prompt            String?
  response          String
  additionalData    String?
  ratingByStudent   Int?
  feedbackByStudent String?
  submissionId      Int
  flavor            String         @default("normal")
  submission        CodeSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model GeneratedFeedback {
  id               String         @id @default(cuid())
  spsContent       String         @db.Text
  kmContent        String         @db.Text
  kcContent        String         @db.Text
  khContent        String         @db.Text
  spsUsedAt        DateTime?
  kmUsedAt         DateTime?
  kcUsedAt         DateTime?
  khUsedAt         DateTime?
  finalPrompt      String         @db.Text
  codeSubmissionId Int // Foreign key to CodeSubmission
  codeSubmission   CodeSubmission @relation(fields: [codeSubmissionId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([codeSubmissionId])
}

model genTaskData {
  id                Int      @id @default(autoincrement())
  timestamp         DateTime @default(now())
  topic             String
  context           String
  taskPrompt        String?  @db.Text
  task              String   @db.Text
  expectationPrompt String?  @db.Text
  expectation       String   @db.Text
  solutionPrompt    String?  @db.Text
  solutionOne       String   @db.Text
  solutionTwo       String?  @db.Text
  solutionThree     String?  @db.Text
  unitTestPrompt    String?  @db.Text
  unitTestOne       String   @db.Text
  unitTestTwo       String?  @db.Text
  unitTestThree     String?  @db.Text
  errorIteration    Int
  isErrorAtEnd      Boolean
  errorOne          String?  @db.Text
  errorTwo          String?  @db.Text
  errorThree        String?  @db.Text
  juryOne           Json?
  juryTwo           Json?
  juryThree         Json?
  codeFramework     String   @db.Text
  runMethod         String?  @db.Text
  runMethodInput    String?  @db.Text
  allTaskData       Json?
  judgeTask         Json?
}

model anonymousUser {
  id            Int         @id @default(autoincrement())
  userId        Int
  anonymousName String      @default("Anonymchen")
  Discussion    Discussion?
  Message       Message[]
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Discussion {
  id               Int      @id @default(autoincrement())
  title            String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  contentNodeId    Int?
  conceptNodeId    Int
  contentElementId Int?
  authorId         Int      @unique
  isSolved         Boolean  @default(false)

  // EVALUATION SYSTEM EXTENSIONS
  evaluationSubmissionId String?
  evaluationCategoryId   Int?

  author         anonymousUser   @relation(fields: [authorId], references: [id])
  conceptNode    ConceptNode     @relation(fields: [conceptNodeId], references: [id])
  contentElement ContentElement? @relation(fields: [contentElementId], references: [id])
  contentNode    ContentNode?    @relation(fields: [contentNodeId], references: [id])
  messages       Message[]
  Notification   Notification[]

  // EVALUATION SYSTEM RELATIONS
  evaluationSubmission EvaluationSubmission? @relation("EvaluationDiscussions", fields: [evaluationSubmissionId], references: [id])
  evaluationCategory   EvaluationCategory?   @relation("CategoryDiscussions", fields: [evaluationCategoryId], references: [id])
}

model Message {
  id           Int           @id @default(autoincrement())
  text         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  authorId     Int
  isInitiator  Boolean       @default(false)
  isSolution   Boolean       @default(false)
  discussionId Int
  author       anonymousUser @relation(fields: [authorId], references: [id])
  discussion   Discussion    @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  votes        Vote[]
}

model Vote {
  id        Int     @id @default(autoincrement())
  isUpvote  Boolean @default(true)
  userId    Int
  messageId Int
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId], name: "unique_vote")
}

model ChatSession {
  id        Int              @id @default(autoincrement())
  title     String
  createdAt DateTime         @default(now())
  userId    Int
  user      User             @relation(fields: [userId], references: [id])
  messages  ChatBotMessage[]
}

model ChatBotMessage {
  id              Int          @id @default(autoincrement())
  question        String
  answer          String?
  createdAt       DateTime     @default(now())
  isBot           Boolean      @default(false)
  ratingByStudent Int?
  usedChunks      String?      @db.Text
  contextUrl      String?      @default("") // Added field to store URL context
  user            User?        @relation(fields: [userId], references: [id])
  userId          Int?
  sessionId       Int?
  session         ChatSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model UserContentElementProgress {
  id               Int            @id @default(autoincrement())
  userId           Int
  contentElementId Int
  markedAsDone     Boolean        @default(false)
  markedAsQuestion Boolean        @default(false)
  updatedAt        DateTime       @updatedAt
  contentElement   ContentElement @relation(fields: [contentElementId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserContentView {
  id            Int         @id @default(autoincrement())
  userId        Int
  contentNodeId Int
  lastOpened    DateTime
  contentNode   ContentNode @relation(fields: [contentNodeId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EventLog {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  type      String
  level     String
  message   String
  userId    Int?
  data      Json?
  User      User?    @relation(fields: [userId], references: [id])
}

model TranscriptEmbedding {
  id      String                 @id @default(cuid())
  content String
  vector  Unsupported("vector")?
  fileId  Int?
  file    File?                  @relation(fields: [fileId], references: [id])
}

model Notification {
  id            Int         @id @default(autoincrement())
  userId        Int?
  message       String
  timestamp     DateTime    @default(now())
  isRead        Boolean     @default(false)
  readTimestamp DateTime?
  type          String
  discussionId  Int?
  discussion    Discussion? @relation(fields: [discussionId], references: [id])
  User          User?       @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([userId, timestamp])
  @@index([type])
  @@index([discussionId])
}

