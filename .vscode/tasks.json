{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Alle HEFL Terminals starten",
      "dependsOn": [
        "Terminal: Client Angular",
        "Terminal: Server NestJS",
        "Terminal: Root"
      ],
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Terminal: Client Angular",
      "type": "shell",
      "command": "",
      "options": {
        "cwd": "${workspaceFolder}/client_angular",
        "shell": {
          "executable": "cmd.exe",
          "args": ["/K"]
        }
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "echo": false,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "Terminal: Server NestJS",
      "type": "shell",
      "command": "",
      "options": {
        "cwd": "${workspaceFolder}/server_nestjs",
        "shell": {
          "executable": "cmd.exe",
          "args": ["/K"]
        }
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "echo": false,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "Terminal: Root",
      "type": "shell",
      "command": "",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "cmd.exe",
          "args": ["/K"]
        }
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "echo": false,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false
      }
    }
  ]
}
