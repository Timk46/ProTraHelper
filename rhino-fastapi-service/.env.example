# Modern Rhino FastAPI Service Configuration
# Copy this file to .env and adjust the values

# Security
RHINO_API_KEY=your-secure-api-key-here-change-this

# Server Configuration
CORS_ORIGINS=http://localhost:4200,http://localhost:8080,https://yourproductiondomain.com

# Logging
LOG_LEVEL=INFO

# Performance Settings
MAX_CONCURRENT_COMMANDS=5
COMMAND_TIMEOUT=30

# File Paths
RHINO_FILES_BASE_PATH=C:\Dev\hefl\files

# Development Settings
DEVELOPMENT_MODE=true
MOCK_RHINO_RESPONSES=false
