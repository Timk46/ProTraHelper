FROM node:18 as build

# Build arguments for production URLs
ARG WEBSITE_URL
ARG SERVER_URL
ARG WEBSOCKET_URL

WORKDIR /usr/local/app

COPY ../client_angular /usr/local/app/
COPY ../shared /usr/local/app/

# Replace placeholders in environment.ts with build arguments
RUN sed -i "s|server: 'http://localhost:3000'|server: '${SERVER_URL}'|" src/environments/environment.ts
RUN sed -i "s|websiteUrl: 'http://localhost:4200'|websiteUrl: '${WEBSITE_URL}'|" src/environments/environment.ts
RUN sed -i "s|production: false|production: true|" src/environments/environment.ts
RUN sed -i "s|websocketUrl: 'http://localhost:3001'|websocketUrl: '${WEBSOCKET_URL}'|" src/environments/environment.ts
# Correct tsconfig paths for shared DTOs within Docker build context
RUN sed -i 's#"\.\./shared/dtos/\*"#"./dtos/\*"#g' tsconfig.app.json


RUN npm i && npm cache clean --force
RUN npm install -g @angular/cli@15.2.8
RUN ng build --configuration production --base-href /

FROM nginx:1.23.4

COPY Docker/nginx.conf /etc/nginx/nginx.conf

RUN rm -rf /usr/share/nginx/html/*

COPY --from=build /usr/local/app/dist/client_angular/browser /usr/share/nginx/html

# Add these lines to fix permissions
RUN chown -R nginx:nginx /usr/share/nginx/html && \
    chmod -R 755 /usr/share/nginx/html

RUN rm -rf /usr/local/app/dist/*

EXPOSE 80
