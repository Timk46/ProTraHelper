FROM node:18
WORKDIR /usr/src/app
COPY ../server_nestjs/package.json .
COPY ../server_nestjs/package-lock.json .
COPY ../server_nestjs .
RUN npm install
RUN npx prisma generate
#RUN npm run seed db seedn klappt hier noch nicht, da datenbankserver noch nicht läuft - muss (noch) manuell gemacht werden
RUN npm run build
EXPOSE 3000
CMD ["node", "dist/main.js"] # hier später ggf. ändern zu: CMD ["node", "dist/src/main"]
